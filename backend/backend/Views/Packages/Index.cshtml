@model IEnumerable<backend.Models.Entities.Packages>

@{
    ViewData["Title"] = "Packages";
    Layout = "_Layout";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">@ViewData["Title"]</h6>
        <a asp-action="Create" class="btn btn-primary btn-sm">Create New</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Package Name</th>
                        <th>Description</th>
                        <th>Price</th>
                        <th>Duration</th>
                        <th>Specialty</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.PackageName</td>
                            <td>@item.Description</td>
                            <td>@item.Price.ToString("C")</td>
                            <td>@item.DurationMinutes minutes</td>
                            <td>@item.Specialty?.SpecialtyName</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.IdPackage" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.IdPackage" class="btn btn-sm btn-info">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.IdPackage" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>